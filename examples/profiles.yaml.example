# Copy this file to $XDG_CONFIG_HOME/coworker/profiles.yaml (default: ~/.config/coworker/profiles.yaml)
#
# Each profile fixes a system prompt, a default-recommended provider, and per-subcommand token budgets.
# Switch with `--profile <name>`; override the recommended provider per call with `--provider <name>`.
#
# Optional `recommended_model` (TUNE-0468): pins a per-profile model, e.g. a
# cheaper doc-reading model for `doc-read` or stronger generation model for `write`
# default globally. Resolution precedence for the model actually sent to the
# API: `--model` flag > profile.recommended_model > provider.default_model
# (mirrors the provider-resolution precedence above). Omitting the field is
# fully backward compatible — falls straight through to the provider default,
# exactly like before this field existed.
#
# Optional `fallback_provider` (TUNE-0132): declare a secondary provider to
# retry on ONCE when the primary returns a retryable error (HTTP 429 rate
# limit or a request timeout). Balance-exhausted (402), auth, and generic
# errors are NOT retried — they would fail identically on any provider.
# The hop is single-flight (at most one). Optional `fallback_model` pins the
# model sent to the fallback provider (defaults to that provider default_model).
# Omitting `fallback_provider` keeps the pre-TUNE-0132 fail-loud behavior.

doc-read:
  description: Literal documentation extraction and summarization
  system_prompt: |
    You extract literal facts from documentation. Summarize, list, compare
    explicit statements, and quote only the short lines that matter. Do not
    invent policy or perform adversarial review. If the answer is not in the
    corpus, say so explicitly.
  default_max_tokens_ask: 16384
  default_max_tokens_write: 8192
  recommended_provider: deepseek
  recommended_model: deepseek-v4-flash
  fallback_provider: openrouter

classifier:
  description: Short routing/classification prompts
  system_prompt: |
    You classify short operational inputs and return the requested compact
    schema. Do not review artifacts, reason about architecture, or generate
    user-facing prose.
  default_max_tokens_ask: 4096
  default_max_tokens_write: 4096
  recommended_provider: deepseek
  recommended_model: deepseek-v4-flash

write:
  description: Boilerplate generation
  system_prompt: |
    You generate complete, production-quality source files. Output ONLY
    the file contents — no preamble, no trailing commentary, no surrounding
    code fences. Match the target file's language idioms.
  default_max_tokens_ask: 8192
  default_max_tokens_write: 24000
  recommended_provider: deepseek
  recommended_model: deepseek-v4-pro

datarim-write:
  description: Datarim artifact first drafts
  system_prompt: |
    You draft Datarim artifacts from explicit instructions and supplied
    context. Preserve required frontmatter and schema conventions. Output only
    the requested artifact body; the caller will review and edit judgment parts.
  default_max_tokens_ask: 8192
  default_max_tokens_write: 24000
  recommended_provider: deepseek
  recommended_model: deepseek-v4-pro

datarim:
  description: Legacy profile; use doc-read for literal ask or datarim-write for write
  system_prompt: |
    This profile is intentionally disabled in Datarim policy. Use doc-read
    for literal documentation extraction and datarim-write for allowed first
    drafts. Do not route artifact review or semantic QA through coworker.
  default_max_tokens_ask: 16384
  default_max_tokens_write: 24000
  recommended_provider: none

code:
  description: Legacy profile; source-code analysis stays native in the selected agent
  system_prompt: |
    This profile is intentionally disabled in Datarim policy. Use the
    selected agent runtime directly for code reading and code analysis.
  default_max_tokens_ask: 16384
  default_max_tokens_write: 24000
  recommended_provider: none

codex:
  description: Legacy profile; Codex runtime reads directly
  system_prompt: |
    This profile is intentionally disabled in Datarim policy. Codex should
    read and analyze files directly unless a literal documentation read uses
    the doc-read profile.
  default_max_tokens_ask: 16384
  default_max_tokens_write: 24000
  recommended_provider: none

social:
  description: Legacy profile; voice-bearing content stays native
  system_prompt: |
    This profile is intentionally disabled in Datarim policy. Voice-bearing
    content should be written by the selected model itself.
  default_max_tokens_ask: 4096
  default_max_tokens_write: 4096
  recommended_provider: none

# Example custom profile — adapt for your own workflow:
# my-profile:
#   description: Domain-specific assistant
#   system_prompt: |
#     <your system prompt here>
#   default_max_tokens_ask: 16384
#   default_max_tokens_write: 24000
#   recommended_provider: openai
#   fallback_provider: openrouter   # retry once on 429/timeout
#   fallback_model: deepseek/deepseek-chat-v3.5
